# /etc/udev/rules.d/99-waffle-nbd.rules
#
# Automatically starts waffle-nbd when a DrawBridge / Waffle floppy reader
# is plugged in and stops it cleanly when removed.
#
# Installation:
#   sudo scripts/install-udev.sh
#
# To find the VID:PID of your adapter:
#   udevadm info /dev/ttyUSB0 | grep -E 'idVendor|idProduct'

# ── Prevent udisks2 from auto-mounting NBD block devices ─────────────────────
# UDISKS_AUTO=0 stops the spurious auto-mount (and the extra tray icon) while
# keeping the device visible to udisks2 so the polkit rule can authorise
# user-initiated unmounts without a password prompt.
KERNEL=="nbd[0-9]*", ENV{UDISKS_AUTO}="0"

# ── FTDI FT230X / Waffle v2 ───────────────────────────────────────────────────
ACTION=="add",    SUBSYSTEM=="tty", ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6015", \
    RUN+="/usr/local/lib/waffle-nbd/waffle-udev.sh add $env{DEVNAME}"
ACTION=="remove", SUBSYSTEM=="tty", ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6015", \
    RUN+="/usr/local/lib/waffle-nbd/waffle-udev.sh remove $env{DEVNAME}"

# ── FTDI FT232RL / classic DrawBridge ────────────────────────────────────────
ACTION=="add",    SUBSYSTEM=="tty", ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6001", \
    RUN+="/usr/local/lib/waffle-nbd/waffle-udev.sh add $env{DEVNAME}"
ACTION=="remove", SUBSYSTEM=="tty", ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6001", \
    RUN+="/usr/local/lib/waffle-nbd/waffle-udev.sh remove $env{DEVNAME}"
