[Desktop Entry]
Version=1.0
Type=Application
Name=DOS Floppy (FAT12/FAT16)
Name[it]=Floppy DOS (FAT12/FAT16)
Comment=Mount a PC DOS FAT12/FAT16 floppy via DrawBridge/Waffle
Comment[it]=Monta un floppy PC DOS FAT12/FAT16 tramite DrawBridge/Waffle
Exec=sh -c 'SCRIPT_DIR=$(dirname $(readlink -f %k)); "$SCRIPT_DIR/scripts/waffle-mount.sh" dos dd'
Icon=ICON_PATH_PLACEHOLDER/dos-floppy.svg
Terminal=false
Categories=System;FileManager;
Keywords=dos;fat;fat12;floppy;drawbridge;waffle;pc;
StartupNotify=false
